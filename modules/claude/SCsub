#!/usr/bin/env python

import methods

Import("env")
Import("env_modules")

env_claude = env_modules.Clone()

# All module code is editor-only (MCP server runs inside the editor).
module_sources = []

if env.editor_build:
    module_sources += Glob("mcp/*.cpp")
    module_sources += Glob("util/*.cpp")
    module_sources += Glob("editor/*.cpp")

    # Embed the Python bridge script as a C++ string literal.
    def make_bridge_script(target, source, env):
        with open(str(source[0]), "r", encoding="utf-8") as f:
            content = f.read()
        with methods.generated_wrapper(str(target[0])) as file:
            file.write(
                f'inline constexpr const char *_claude_mcp_bridge_script = R"SCRIPT({content})SCRIPT";\n'
            )

    env.CommandNoCache(
        "bridge/claude_mcp_bridge.gen.h",
        "bridge/claude_mcp_bridge.py",
        env.Run(make_bridge_script, "Generating claude_mcp_bridge.gen.h"),
    )

# Root registration files (always compiled, but gated by TOOLS_ENABLED).
module_sources += Glob("*.cpp")

env_claude.add_source_files(env.modules_sources, module_sources)
